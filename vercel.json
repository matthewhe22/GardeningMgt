{
  "regions": ["syd1"],
  "functions": {
    "api/index.js": {
      "includeFiles": "{views,public,node_modules/pdfkit/js/data}/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/cron/reminders", "schedule": "0 20 * * *" }
  ]
}
