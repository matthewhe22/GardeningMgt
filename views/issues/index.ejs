<%- include('../partials/header') %>
<h1>Issues</h1>

<div class="card">
  <form method="get" class="filter-row">
    <label>Search <input type="text" name="search" value="<%= search %>" placeholder="Title or site"></label>
    <label>Status
      <select name="status">
        <option value="">All</option>
        <% ['open','in_progress','resolved','closed'].forEach(s => { %>
          <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn">Filter</button>
  </form>
</div>

<details class="card" <%= (presetPropertyId || presetVisitId) ? 'open' : '' %>>
  <summary><strong>＋ Report an issue</strong></summary>
  <% if (presetVisitId) { %>
    <p class="muted">Reporting from <a href="/visits/<%= presetVisitId %>">visit #<%= presetVisitId %></a> — its site is pre-selected below.</p>
  <% } %>
  <form method="post" action="/issues" enctype="multipart/form-data" class="form-grid" data-upload data-draft-label="issue">
    <input type="hidden" name="visit_id" value="<%= presetVisitId || '' %>">
    <label class="span2">Title <input type="text" name="title" required></label>
    <label class="span2">Description <textarea name="description" rows="3"></textarea></label>
    <label>Property
      <select name="property_id">
        <option value="">—</option>
        <% properties.forEach(p => { %><option value="<%= p.id %>" <%= presetPropertyId === p.id ? 'selected' : '' %>><%= p.name %></option><% }) %>
      </select>
    </label>
    <label>Priority
      <select name="priority">
        <% ['low','medium','high','urgent'].forEach(p => { %>
          <option value="<%= p %>" <%= p === 'medium' ? 'selected' : '' %>><%= p %></option>
        <% }) %>
      </select>
    </label>
    <% if (staff) { %>
    <label>Assign to
      <select name="assigned_to">
        <option value="">Unassigned</option>
        <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }) %>
      </select>
    </label>
    <% } %>
    <label class="span2">Photo (optional)
      <input type="file" name="photos" accept="image/*" capture="environment" multiple>
    </label>
    <div class="photo-previews span2" data-upload-previews hidden></div>
    <p class="upload-status muted span2" data-upload-status hidden></p>
    <button class="btn btn-primary">Report issue</button>
  </form>
</details>

<div class="card">
  <table class="table table--stack">
    <tr class="thead-row"><th>Issue</th><th>Property</th><th>Priority</th><th>Status</th><th>Assignee</th><th>Reported</th></tr>
    <% issues.forEach(i => { %>
    <tr>
      <td class="stack-main"><a href="/issues/<%= i.id %>"><strong><%= i.title %></strong></a></td>
      <td class="muted" data-label="Property"><%= i.property_name || '—' %></td>
      <td data-label="Priority"><span class="prio prio-<%= i.priority %>"><%= i.priority %></span></td>
      <td data-label="Status"><span class="status status-<%= i.status %>"><%= i.status.replace('_',' ') %></span></td>
      <td data-label="Assignee"><%= i.assignee_name || '—' %></td>
      <td class="muted" data-label="Reported"><%= fmtDateTime(i.created_at) %> · <%= i.reporter_name || '' %></td>
    </tr>
    <% }) %>
  </table>
  <% if (!issues.length) { %><p class="muted">No issues found.</p><% } %>
</div>
<%- include('../partials/pagination') %>
<%- include('../partials/footer') %>
