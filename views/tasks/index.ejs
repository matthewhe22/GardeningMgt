<%- include('../partials/header') %>
<h1>Tasks</h1>

<div class="card">
  <form method="get" class="filter-row">
    <label>Status
      <select name="status">
        <option value="">All</option>
        <% ['pending','in_progress','done','blocked'].forEach(s => { %>
          <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn">Filter</button>
  </form>
</div>

<% if (staff) { %>
<details class="card">
  <summary><strong>＋ New standalone task</strong></summary>
  <form method="post" action="/tasks" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label class="span2">Title <input type="text" name="title" required></label>
    <label class="span2">Description <input type="text" name="description"></label>
    <label>Assignee
      <select name="assignee_id">
        <option value="">Unassigned</option>
        <% gardeners.forEach(g => { %><option value="<%= g.id %>"><%= g.name %></option><% }) %>
      </select>
    </label>
    <label>Due date <input type="date" name="due_date"></label>
    <button class="btn btn-primary">Create task</button>
  </form>
</details>
<% } %>

<div class="card">
  <table class="table table--stack">
    <tr class="thead-row"><th>Task</th><th>Assignee</th><th>Due / visit</th><th>Status</th><th>Change</th></tr>
    <% tasks.forEach(t => { %>
    <tr>
      <td class="stack-main"><strong><%= t.title %></strong>
        <% if (t.property_name) { %><br><span class="muted"><%= t.property_name %></span><% } %>
        <% if (t.description) { %><br><span class="muted"><%= t.description %></span><% } %>
        <% if (staff) { %>
        <details class="row-edit">
          <summary>Edit</summary>
          <form method="post" action="/tasks/<%= t.id %>/update" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <label class="span2">Title <input type="text" name="title" value="<%= t.title %>" required></label>
            <label class="span2">Description <input type="text" name="description" value="<%= t.description || '' %>"></label>
            <label>Assignee
              <select name="assignee_id">
                <option value="">Unassigned</option>
                <% gardeners.forEach(g => { %><option value="<%= g.id %>" <%= String(g.id) === String(t.assignee_id) ? 'selected' : '' %>><%= g.name %></option><% }) %>
              </select>
            </label>
            <label>Due date <input type="date" name="due_date" value="<%= t.due_date || '' %>"<% if (t.visit_ref) { %> title="This task is linked to a visit; the list shows the visit date"<% } %>></label>
            <button class="btn btn-primary btn-sm">Save changes</button>
          </form>
        </details>
        <% } %></td>
      <td data-label="Assignee"><%= t.assignee_name || '—' %></td>
      <td class="muted" data-label="Due / visit">
        <% if (t.visit_ref) { %><a href="/visits/<%= t.visit_ref %>"><%= t.scheduled_date %></a>
        <% } else { %><%= t.due_date || '—' %><% } %>
      </td>
      <td data-label="Status"><span class="status status-<%= t.status %>"><%= t.status.replace('_',' ') %></span></td>
      <td data-label="Change">
        <form method="post" action="/tasks/<%= t.id %>/status" class="inline"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <select name="status" data-autosubmit aria-label="Change task status">
            <% ['pending','in_progress','done','blocked'].forEach(s => { %>
              <option value="<%= s %>" <%= t.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
            <% }) %>
          </select>
        </form>
      </td>
    </tr>
    <% }) %>
  </table>
  <% if (!tasks.length) { %>
    <div class="empty">
      <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
      <p>No tasks found.</p>
    </div>
  <% } %>
</div>
<%- include('../partials/pagination') %>
<%- include('../partials/footer') %>
