<%- include('../partials/header') %>

<div class="page-head job-head">
  <h1><%= visit.property_name %></h1>
  <div class="chips">
    <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M8 3v4M16 3v4M3.5 10h17"/></svg> <%= visit.scheduled_date %><% if (visit.time_window) { %> · <%= visit.time_window %><% } %></span>
    <a class="chip chip-link" href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent((visit.lat != null && visit.lng != null) ? (visit.lat + ',' + visit.lng) : (visit.property_name + ', ' + visit.address)) %>" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m15 9-2 6-6 2 2-6 6-2Z"/></svg> Navigate</a>
    <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s7-6.5 7-11.5A7 7 0 0 0 5 9.5C5 14.5 12 21 12 21Z"/><circle cx="12" cy="9.5" r="2.3"/></svg> <%= visit.address %></span>
    <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.6"/><path d="M4.5 20a7.5 7.5 0 0 1 15 0"/></svg> <%= visit.gardener_name || 'Unassigned' %></span>
    <span class="status status-<%= visit.status %>"><%= visit.status.replace('_',' ') %></span>
    <% if (locals.job && job.default_gardener_name && visit.gardener_name && job.gardener_id !== visit.gardener_id) { %>
      <span class="status status-in_progress">replacement for <%= job.default_gardener_name %></span>
    <% } %>
  </div>
  <p class="page-sub"><a class="btn btn-sm" href="/issues?property_id=<%= visit.property_id %>&visit_id=<%= visit.id %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Report an issue at this site</a></p>
  <% if (locals.warning === 'busy') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Heads up: this gardener already has other visits scheduled that day — check for a clash.</p>
  <% } %>
  <% if (locals.flash === 'photos') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Add at least one photo for this site before completing the job.</p>
  <% } else if (locals.flash === 'confirm') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Please tick the confirmation box to complete the job.</p>
  <% } else if (locals.flash === 'invalid') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Some details were invalid — please check and try again.</p>
  <% } else if (locals.flash === 'badphoto') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> One or more photos couldn't be uploaded — please check the file and try again.</p>
  <% } else if (locals.flash === 'piqconfirm') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Please tick the confirmation box to send the report to owners.</p>
  <% } else if (locals.flash === 'piqnotconfigured') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> PropertyIQ isn't configured yet — set it up on <a href="/admin/settings">Settings</a>.</p>
  <% } else if (locals.flash === 'piqnomatch') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Couldn't find a matching PropertyIQ building for this site's address.</p>
  <% } else if (locals.flash === 'piqerror') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> PropertyIQ couldn't be reached just now — please try again shortly.</p>
  <% } else if (locals.flash === 'piqnoemails') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Matched the PropertyIQ building, but it has no lot owner email addresses on file.</p>
  <% } else if (locals.flash === 'piqsendfailed') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> Owner emails were found, but sending failed — check the Email (SMTP) setup on Settings.</p>
  <% } else if (locals.flash === 'piqsent') { %>
    <p class="alert alert-ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg> Report sent to the building's owners via PropertyIQ.</p>
  <% } else if (locals.flash === 'piqstale') { %>
    <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> This site's details changed since you looked up the owners — please review them again before sending.</p>
  <% } %>
  <% if (locals.job) { %>
  <p class="page-sub"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg> <%= job.frequency %> · <%= job.contract_years %>-year contract
    (<%= job.start_date %> → <%= job.end_date %>)
    · last completed: <%= job.last_completed_at ? fmtDateTime(job.last_completed_at) : 'never' %>
    <% if (staff) { %> · <a href="/jobs/site/<%= visit.property_id %>">site history</a><% } %>
    · <a href="/jobs">all sites</a></p>
  <% } %>
</div>

<!-- ===== 1. The job action: start / complete ===== -->
<div class="card timer-card"<% if (visit.started_at && !visit.finished_at) { %> data-gps-ping-visit="<%= visit.id %>"<% } %>>
  <% if (visit.started_at && !visit.finished_at) { %>
    <h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l3 2"/><path d="M9 2h6"/></svg> Job running</h2>
    <p>Started at <strong><%= fmtDateTime(visit.started_at) %></strong>.</p>
    <p class="muted">Completing records the date &amp; time, notifies your supervisor,
      and files the report and photos.</p>
    <% if (locals.longRunning) { %>
      <p class="alert alert-error">⏰ This job has been running for over 4 hours — still working?
        (If the timer was left on by mistake, a supervisor can correct the recorded hours after you complete the job.)</p>
    <% } %>
    <form method="post" action="/visits/<%= visit.id %>/timer/stop" class="gps-form mobile-sticky-cta"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="lat"><input type="hidden" name="lng">
      <p class="cta-note"><strong><%= photos.length %></strong> photo(s) uploaded for this site so far.
        <% if (!photos.length) { %><br><span class="muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> <a href="#photos">Upload your photos</a> before completing.</span><% } %></p>
      <label class="confirm-line"><input type="checkbox" name="confirm_photos" required>
        I confirm all photos for this site have been uploaded</label>
      <button class="btn btn-danger btn-block"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg> Complete job</button>
    </form>
  <% } else if (visit.finished_at) { %>
    <h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg> Job completed</h2>
    <p>Worked <strong><%= visit.duration_minutes %> min</strong>
      (<%= fmtDateTime(visit.started_at) %> → <%= fmtDateTime(visit.finished_at) %>).</p>
    <div class="btn-row">
      <a class="btn btn-primary" href="/visits/<%= visit.id %>/report" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h9l4 4v14H6V3Z"/><path d="M14.5 3.5V8H19"/><path d="M9.5 13H15"/><path d="M9.5 16.5H15"/></svg> View report</a>
      <a class="btn" href="/visits/<%= visit.id %>/report?download=1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M4 19.5h16"/></svg> Download PDF</a>
      <form method="post" action="/visits/<%= visit.id %>/timer/start" class="gps-form inline" data-confirm="Restart the timer? This clears the recorded completion time and reopens the job."><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <input type="hidden" name="lat"><input type="hidden" name="lng">
        <button class="btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12a8 8 0 1 1-2.6-5.9"/><path d="M20 4v5h-5"/></svg> Restart timer</button>
      </form>
    </div>
    <% if (staff) { %>
    <div class="card" style="margin-top:16px">
      <h3 class="next-stop-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="m4 6 8 7 8-7"/></svg> Send report to owners</h3>
      <p class="muted">Once you've reviewed the report and it's ready to go out, confirm below. Owners are
        looked up from PropertyIQ by matching this site's address to a PropertyIQ building — you'll see the
        matched building and the exact recipient list to check before anything is sent.</p>
      <form method="post" action="/visits/<%= visit.id %>/report/owners/preview" class="gps-form"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <label class="confirm-line"><input type="checkbox" name="confirm_report" required>
          I confirm this job report is satisfactory and ready to send to the owners</label>
        <button class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg> Look up owners &amp; review
        </button>
      </form>
    </div>
    <% } %>
    <% if (locals.nextVisit) { %>
    <div class="next-stop-card">
      <h3 class="next-stop-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12h16"/><path d="m13 5 7 7-7 7"/></svg> Next stop</h3>
      <p><strong><%= nextVisit.property_name %></strong> — <%= nextVisit.address %>
        <% if (nextVisit.time_window) { %><span class="muted">(<%= nextVisit.time_window %>)</span><% } %></p>
      <div class="btn-row">
        <a class="btn btn-primary" href="/visits/<%= nextVisit.id %>">Open job</a>
        <a class="btn" href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent((nextVisit.lat != null && nextVisit.lng != null) ? (nextVisit.lat + ',' + nextVisit.lng) : (nextVisit.property_name + ', ' + nextVisit.address)) %>" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m15 9-2 6-6 2 2-6 6-2Z"/></svg> Navigate</a>
      </div>
    </div>
    <% } %>
    <% if (staff) { %>
    <details class="manage-duration">
      <summary class="muted">Correct recorded hours (staff)</summary>
      <p class="muted">A skipped or forgotten timer can leave the worked time wrong — this
        feeds invoicing and the hours-worked report, so correct it here rather than editing it
        anywhere else. The change is logged with who made it and the previous value.</p>
      <form method="post" action="/visits/<%= visit.id %>/duration" class="filter-row"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <label>Minutes worked <input type="number" name="duration_minutes" min="0" step="1" value="<%= visit.duration_minutes || 0 %>" required></label>
        <button class="btn">Save correction</button>
      </form>
    </details>
    <% } %>
  <% } else { %>
    <h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l3 2"/><path d="M9 2h6"/></svg> Ready to start</h2>
    <p class="muted">Your GPS position is recorded when you start and finish
      (if location access is allowed).</p>
    <form method="post" action="/visits/<%= visit.id %>/timer/start" class="gps-form mobile-sticky-cta"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="lat"><input type="hidden" name="lng">
      <button class="btn btn-primary btn-block">▶ Start job</button>
    </form>
  <% } %>

  <% if (!staff && !visit.finished_at) { %>
    <form method="post" action="/visits/<%= visit.id %>/status" class="skip-job-form"
      data-confirm="Mark this job as skipped? Use this only if the job genuinely can't be done today (e.g. site inaccessible, no one home). Your supervisor will see it as skipped.">
      <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="status" value="skipped">
      <button class="btn btn-block skip-job-btn" type="submit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg> Can't do this job</button>
    </form>
  <% } %>

  <% if (locals.mapSvg && (visit.started_at || gpsPoints.length)) { %>
    <div class="map-snapshot">
      <h3 class="map-snapshot-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s7-6.5 7-11.5A7 7 0 0 0 5 9.5C5 14.5 12 21 12 21Z"/><circle cx="12" cy="9.5" r="2.3"/></svg> Job location</h3>
      <%- mapSvg %>
      <p class="muted">From the GPS captured on this visit.<% if (locals.mapLink) { %>
        · <a href="<%= mapLink %>" target="_blank" rel="noopener">Open in map ↗</a><% } %></p>
    </div>
  <% } %>

  <% if (gpsPoints.length) { %>
    <details><summary class="muted"><%= gpsPoints.length %> GPS point(s) recorded</summary>
      <table class="table">
        <tr><th>Kind</th><th>Coordinates</th><th>Recorded</th></tr>
        <% gpsPoints.forEach(g => { %>
          <tr><td><%= g.kind %></td><td><%= g.lat.toFixed(5) %>, <%= g.lng.toFixed(5) %></td><td class="muted"><%= fmtDateTime(g.recorded_at) %></td></tr>
        <% }) %>
      </table>
    </details>
  <% } %>
  <details>
    <summary class="muted">Change visit date</summary>
    <form method="post" action="/visits/<%= visit.id %>/reschedule" class="filter-row"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <label>New date <input type="date" name="scheduled_date" value="<%= visit.scheduled_date %>" required></label>
      <button class="btn">Move visit</button>
    </form>
  </details>
</div>

<!-- ===== 2. The work: tasks, photos, comments ===== -->
<div class="grid">
  <section class="card" id="tasks">
    <h2>Tasks</h2>
    <table class="table table-tasks">
      <% tasks.forEach(t => { %>
      <tr>
        <td class="task-main">
          <div class="task-title-line">
            <strong><%= t.title %></strong>
            <span class="status status-<%= t.status %>"><%= t.status.replace('_',' ') %></span>
          </div>
          <% if (t.description) { %><span class="muted"><%= t.description %></span><% } %>
        </td>
        <td class="task-status-cell">
          <form method="post" action="/tasks/<%= t.id %>/status" class="inline"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <select name="status" data-autosubmit aria-label="Change task status">
              <% ['pending','in_progress','done','blocked'].forEach(s => { %>
                <option value="<%= s %>" <%= t.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
              <% }) %>
            </select>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
    <% if (!tasks.length) { %>
      <div class="empty">
        <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
        <p>No tasks for this visit.</p>
      </div>
    <% } %>
    <form method="post" action="/visits/<%= visit.id %>/tasks" class="add-row" data-draft-label="task"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="text" name="title" placeholder="New task…" required>
      <button class="btn">Add</button>
    </form>
  </section>

  <section class="card" id="photos">
    <h2>Photos <span class="muted">(<%= photos.length %>)</span></h2>
    <div class="photo-grid">
      <% photos.forEach(ph => { %>
        <figure class="photo">
          <a href="/uploads/<%= ph.filename %>" target="_blank"><img src="/uploads/<%= ph.filename %>/thumb" alt="<%= ph.caption || ph.original_name %>" loading="lazy"></a>
          <figcaption>
            <span class="photo-stamp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M8 3v4M16 3v4M3.5 10h17"/></svg> <%= fmtDateTime(ph.created_at) %></span><br>
            <% if (ph.caption) { %><%= ph.caption %> · <% } %><span class="muted">by <%= ph.uploader_name %></span>
            <% if (staff || ph.uploaded_by === user.id) { %>
              <form method="post" action="/photos/<%= ph.id %>/delete" class="inline" data-confirm="Delete this photo?"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %><button class="link-btn link-btn-danger">Delete</button></form>
            <% } %>
          </figcaption>
        </figure>
      <% }) %>
    </div>
    <% if (!photos.length) { %>
      <div class="empty">
        <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h3l2-2.5h6L17 7h3a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.5"/></svg></span>
        <p>No photos yet — add them before completing the job.</p>
      </div>
    <% } %>
    <form method="post" action="/visits/<%= visit.id %>/photos" enctype="multipart/form-data" class="photo-upload" data-upload data-draft-label="photo caption"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <div class="photo-actions">
        <label class="btn btn-primary photo-pick" data-camera>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h3l2-2.5h6L17 7h3a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.5"/></svg> Take photo
          <input type="file" name="photos" accept="image/*" capture="environment" multiple hidden>
        </label>
        <label class="btn photo-pick" data-library>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="4.5" width="17" height="15" rx="2"/><circle cx="8.5" cy="9.5" r="1.6"/><path d="m4 17 5-5 3.5 3.5L17 10l3 3"/></svg> Choose from library
          <input type="file" name="photos" accept="image/*" multiple hidden>
        </label>
      </div>
      <div class="photo-previews" data-upload-previews hidden></div>
      <p class="upload-status muted" data-upload-status hidden></p>
      <label>Caption <input type="text" name="caption" placeholder="Optional note for these photos"></label>
      <label class="confirm-line share-line"><input type="checkbox" name="shared" checked> Share with the whole team</label>
      <button class="btn btn-primary btn-block" type="submit" data-upload-submit>Upload photos</button>
      <p class="muted">On a phone you can snap a picture with the camera or pick from your
        library. Every photo is timestamped automatically.</p>
    </form>
  </section>

  <section class="card" id="comments">
    <h2>Comments</h2>
    <% comments.forEach(c => { %>
      <div class="comment">
        <strong><%= c.author_name %></strong> <span class="tag tag-<%= c.author_role %>"><%= c.author_role %></span>
        <span class="muted"><%= fmtDateTime(c.created_at) %></span>
        <p><%= c.body %></p>
        <% (photosByComment[c.id] || []).forEach(ph => { %>
          <figure class="photo comment-photo">
            <a href="/uploads/<%= ph.filename %>" target="_blank"><img src="/uploads/<%= ph.filename %>/thumb" alt="comment photo" loading="lazy"></a>
            <figcaption><span class="photo-stamp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M8 3v4M16 3v4M3.5 10h17"/></svg> <%= fmtDateTime(ph.created_at) %></span></figcaption>
          </figure>
        <% }) %>
      </div>
    <% }) %>
    <% if (!comments.length) { %>
      <div class="empty">
        <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5.5h16v10H9l-4 3.5v-3.5H4Z"/></svg></span>
        <p>No comments yet.</p>
      </div>
    <% } %>
    <form method="post" action="/visits/<%= visit.id %>/comments" enctype="multipart/form-data" class="comment-form" data-upload data-draft-label="comment"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <textarea name="body" rows="2" placeholder="Add a comment…" required></textarea>
      <div class="comment-actions">
        <label class="btn comment-attach photo-pick" data-camera>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 12.5 15 4.5a3.2 3.2 0 0 1 4.5 4.5l-9 9a5 5 0 0 1-7-7l8.5-8.5"/></svg> Attach photo
          <input type="file" name="photos" accept="image/*" multiple hidden>
        </label>
        <span class="upload-status muted" data-upload-status hidden></span>
        <button class="btn btn-primary comment-send" type="submit">Send</button>
      </div>
      <div class="photo-previews" data-upload-previews hidden></div>
      <p class="muted">Staff comments notify the assigned gardener; gardener comments notify supervisors and admins.</p>
    </form>
  </section>
</div>

<!-- ===== 3. Staff-only management, kept out of the gardener's way ===== -->
<% if (staff) { %>
<details class="card manage-card">
  <summary><strong><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3.2"/><path d="M19.4 13.5a1.6 1.6 0 0 0 .32 1.76l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.6 1.6 0 0 0-1.76-.32 1.6 1.6 0 0 0-.97 1.46V19.5a2 2 0 1 1-4 0v-.09a1.6 1.6 0 0 0-1.05-1.46 1.6 1.6 0 0 0-1.76.32l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.6 1.6 0 0 0 .32-1.76 1.6 1.6 0 0 0-1.46-.97H4.5a2 2 0 1 1 0-4h.09a1.6 1.6 0 0 0 1.46-1.05 1.6 1.6 0 0 0-.32-1.76l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.6 1.6 0 0 0 1.76.32h.09a1.6 1.6 0 0 0 .97-1.46V4.5a2 2 0 1 1 4 0v.09a1.6 1.6 0 0 0 .97 1.46 1.6 1.6 0 0 0 1.76-.32l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.6 1.6 0 0 0-.32 1.76v.09a1.6 1.6 0 0 0 1.46.97h.09a2 2 0 1 1 0 4h-.09a1.6 1.6 0 0 0-1.46.97Z"/></svg> Manage job</strong> <span class="muted">— reassign, reschedule, status, invoice (staff only)</span></summary>
  <form method="post" action="/visits/<%= visit.id %>/update" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Gardener
      <select name="gardener_id">
        <option value="">Unassigned</option>
        <% gardeners.forEach(g => { %>
          <option value="<%= g.id %>" <%= visit.gardener_id === g.id ? 'selected' : '' %>><%= g.name %></option>
        <% }) %>
      </select>
    </label>
    <label>Date <input type="date" name="scheduled_date" value="<%= visit.scheduled_date %>" required></label>
    <label>Time window <input type="text" name="time_window" value="<%= visit.time_window || '' %>" placeholder="08:00-10:00"
      pattern="([01]\d|2[0-3]):[0-5]\d-([01]\d|2[0-3]):[0-5]\d" title="Format HH:MM-HH:MM, e.g. 08:00-10:00"></label>
    <label>Status
      <select name="status">
        <% ['scheduled','in_progress','completed','skipped','cancelled'].forEach(s => { %>
          <option value="<%= s %>" <%= visit.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
        <% }) %>
      </select>
    </label>
    <label>Duration (min) <input type="number" name="duration_minutes" value="<%= visit.duration_minutes || '' %>"></label>
    <label class="span2">Notes <input type="text" name="notes" value="<%= visit.notes || '' %>"></label>
    <button class="btn btn-primary">Save changes</button>
  </form>
  <hr>
  <h3>Invoice</h3>
  <% if (invoice) { %>
    <p><a class="btn" href="/invoices/<%= invoice.id %>">View <%= invoice.number %> (<%= invoice.status %>)</a></p>
  <% } else { %>
    <form method="post" action="/invoices"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="visit_id" value="<%= visit.id %>">
      <button class="btn">Create invoice for this job</button>
    </form>
  <% } %>
</details>
<% } %>
<% if (!visit.finished_at) { %><div class="cta-spacer" aria-hidden="true"></div><% } %>
<%- include('../partials/footer') %>
