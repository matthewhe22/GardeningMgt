<%- include('../partials/header') %>
<div class="page-head">
  <h1>Jobs</h1>
  <p class="page-sub">Visits grouped by day, nearest first. Tap a job to start the timer, upload photos and complete it.</p>
</div>

<div class="card">
  <%
    // Build a /visits link that keeps the current gardener filter, with the
    // given scope params merged in.
    const vlink = (extra = {}) => {
      const p = new URLSearchParams();
      if (gardenerId) p.set('gardener_id', String(gardenerId));
      for (const k in extra) if (extra[k]) p.set(k, extra[k]);
      const s = p.toString();
      return '/visits' + (s ? '?' + s : '');
    };
    const isToday = !date && upto === today;
    const isAll = !date && !upto && showAll;
    const isUpcoming = !date && !upto && !showAll;
  %>
  <div class="quick-filters">
    <a class="chip quick-chip<%= isToday ? ' is-active' : '' %>" href="<%= vlink({ upto: today }) %>">📅 Today &amp; overdue</a>
    <a class="chip quick-chip<%= isUpcoming ? ' is-active' : '' %>" href="<%= vlink() %>">Upcoming</a>
    <a class="chip quick-chip<%= isAll ? ' is-active' : '' %>" href="<%= vlink({ all: '1' }) %>">All dates</a>
  </div>
  <form method="get" class="filter-row">
    <label>Date <input type="date" name="date" value="<%= date %>"></label>
    <% if (staff) { %>
    <label>Gardener
      <select name="gardener_id">
        <option value="">All</option>
        <% gardeners.forEach(g => { %>
          <option value="<%= g.id %>" <%= String(g.id) === String(gardenerId) ? 'selected' : '' %>><%= g.name %></option>
        <% }) %>
      </select>
    </label>
    <% } %>
    <button class="btn">Filter</button>
  </form>
  <% if (staff && !gardenerId) { %>
    <p class="muted reorder-hint">Pick a single gardener to reorder or optimize their visiting sequence.</p>
  <% } %>
</div>

<% if (staff) { %>
<details class="card">
  <summary><strong>＋ Schedule a one-off visit</strong> <span class="muted">(recurring jobs are created on the Sites page)</span></summary>
  <form method="post" action="/visits" class="form-grid">
    <label>Property
      <select name="property_id" required>
        <% properties.forEach(p => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %>
      </select>
    </label>
    <label>Gardener
      <select name="gardener_id">
        <option value="">Unassigned</option>
        <% gardeners.forEach(g => { %><option value="<%= g.id %>"><%= g.name %></option><% }) %>
      </select>
    </label>
    <label>Date <input type="date" name="scheduled_date" required></label>
    <label>Time window <input type="text" name="time_window" placeholder="08:00-10:00"></label>
    <label class="span2">Notes <input type="text" name="notes"></label>
    <button class="btn btn-primary">Schedule visit</button>
  </form>
</details>
<% } %>

<% if (status || from || to) { %>
<div class="card filter-active">
  <div>Showing
    <% if (status) { %><span class="status status-<%= status %>"><%= status.replace('_',' ') %></span> <% } %>
    visits<% if (from || to) { %> · <%= from || '…' %> → <%= to || '…' %><% } %>
    · <strong><%= visits.length %></strong> found
  </div>
  <a class="btn btn-sm" href="/visits">✕ Clear filter</a>
</div>
<% } %>

<% groups.forEach(group => { %>
  <div class="day-group">
    <div class="day-head">
      <h2 class="day-title">
        <%= group.date %>
        <% if (group.date === today) { %><span class="status status-in_progress">Today</span>
        <% } else if (group.date < today) { %><span class="status status-open">Delayed</span><% } %>
        <span class="muted">· <%= group.items.length %> stop<%= group.items.length === 1 ? '' : 's' %></span>
      </h2>
      <% if (canReorder && group.items.length > 1) { %>
      <form method="post" action="/visits/optimize" class="inline">
        <input type="hidden" name="date" value="<%= group.date %>">
        <input type="hidden" name="gardener_id" value="<%= gardenerId %>">
        <button class="btn btn-sm">⚡ Optimize route</button>
      </form>
      <% } %>
    </div>

    <div class="job-list">
      <% group.items.forEach((v, i) => { %>
      <div class="job-row card" id="v<%= v.id %>">
        <span class="route-no"><%= v.route_order || '·' %></span>
        <a class="job-row-main" href="/visits/<%= v.id %>">
          <strong><%= v.property_name %></strong>
          <span class="muted"><%= v.address %></span>
        </a>
        <span class="job-row-meta">
          <span class="muted"><% if (v.time_window) { %><%= v.time_window %><% } %><% if (staff) { %> · 👤 <%= v.gardener_name || 'Unassigned' %><% } %><% if (v.duration_minutes) { %> · <%= v.duration_minutes %> min<% } %></span>
          <span class="status status-<%= v.status %>"><%= v.status.replace('_',' ') %></span>
        </span>
        <% if (canReorder) { %>
        <span class="reorder" aria-label="Reorder visit">
          <form method="post" action="/visits/<%= v.id %>/move" class="inline">
            <input type="hidden" name="dir" value="up">
            <button class="reorder-btn" aria-label="Move earlier"<%= i === 0 ? ' disabled' : '' %>>▲</button>
          </form>
          <form method="post" action="/visits/<%= v.id %>/move" class="inline">
            <input type="hidden" name="dir" value="down">
            <button class="reorder-btn" aria-label="Move later"<%= i === group.items.length - 1 ? ' disabled' : '' %>>▼</button>
          </form>
        </span>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
<% }) %>

<% if (!visits.length) { %><div class="card"><p class="muted">No visits match this filter.</p></div><% } %>
<%- include('../partials/footer') %>
