<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Job report #<%= visit.id %> — <%= visit.property_name %></title>
<style>
  body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; color: #1d2620; margin: 0; background: #fff; font-size: 13px; }
  .wrap { max-width: 720px; margin: 0 auto; padding: 22px 20px; }
  header { border-bottom: 2px solid #14532d; padding-bottom: 10px; margin-bottom: 14px; }
  h1 { font-size: 1.2rem; margin: 0; color: #14532d; }
  h2 { font-size: 0.9rem; margin: 16px 0 6px; color: #14532d; border-bottom: 1px solid #e6e4dc; padding-bottom: 3px; }
  .meta { color: #707b72; font-size: 0.82rem; margin-top: 3px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  td, th { text-align: left; padding: 3px 8px; border-bottom: 1px solid #eee; vertical-align: top; }
  th { width: 170px; color: #707b72; font-weight: 600; }
  .pill { display: inline-block; padding: 1px 10px; border-radius: 999px; font-size: 0.74rem; background: #e3f5ea; color: #15803d; }
  /* Compact photos: small tiles keep the report short, but each photo is shown
     whole (uncropped) at the column width, so aspect ratios are preserved. */
  .photos { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 8px; align-items: start; }
  figure { margin: 0; }
  img { width: 100%; height: auto; border-radius: 6px; border: 1px solid #e6e4dc; display: block; }
  figcaption { font-size: 0.68rem; color: #707b72; margin-top: 2px; line-height: 1.25; }
  .stamp { background: #14532d; color: #fff; padding: 1px 6px; border-radius: 4px; font-size: 0.66rem; }
  .comment { border-left: 3px solid #e6e4dc; padding: 3px 10px; margin: 6px 0; font-size: 0.85rem; }
  /* Smaller location map. */
  .map-snapshot { max-width: 360px; margin: 4px 0 6px; }
  .map-snapshot svg { width: 100%; height: auto; }
  footer { margin-top: 22px; color: #707b72; font-size: 0.72rem; border-top: 1px solid #e6e4dc; padding-top: 8px; }
  @media print {
    .no-print { display: none; }
    h2 { break-after: avoid; }
    figure, .comment { break-inside: avoid; }
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>🌱 Job completion report — #<%= visit.id %></h1>
    <p class="meta"><%= visit.property_name %>, <%= visit.address %> · <%= visit.scheduled_date %></p>
  </header>

  <h2>Job details</h2>
  <table>
    <tr><th>Site</th><td><%= visit.property_name %> — <%= visit.address %>
      <% if (visit.lots != null) { %> (<%= visit.lots %> lots)<% } %></td></tr>
    <% if (visit.contact_name) { %><tr><th>Site contact</th><td><%= visit.contact_name %></td></tr><% } %>
    <% if (visit.contact_email) { %><tr><th>Contact email</th><td><a href="mailto:<%= visit.contact_email %>"><%= visit.contact_email %></a></td></tr><% } %>
    <tr><th>Gardener</th><td><%= visit.gardener_name || 'Unassigned' %></td></tr>
    <tr><th>Status</th><td><span class="pill"><%= visit.status.replace('_',' ') %></span></td></tr>
    <tr><th>Scheduled date</th><td><%= visit.scheduled_date %><% if (visit.time_window) { %> · <%= visit.time_window %><% } %></td></tr>
    <% if (visit.started_at) { %><tr><th>Started</th><td><%= fmtDateTime(visit.started_at) %></td></tr><% } %>
    <% if (visit.finished_at) { %><tr><th>Completed</th><td><strong><%= fmtDateTime(visit.finished_at) %></strong></td></tr><% } %>
    <% if (visit.duration_minutes != null) { %><tr><th>Time on site</th><td><%= visit.duration_minutes %> minutes</td></tr><% } %>
    <% if (visit.notes) { %><tr><th>Notes</th><td><%= visit.notes %></td></tr><% } %>
    <% if (job) { %>
      <tr><th>Recurring schedule</th><td><%= job.frequency %> · <%= job.contract_years %>-year contract
        (<%= job.start_date %> → <%= job.end_date %>) · default gardener: <%= job.default_gardener_name || '—' %></td></tr>
    <% } %>
  </table>

  <% if (tasks.length) { %>
  <h2>Tasks (<%= tasks.filter(t => t.status === 'done').length %>/<%= tasks.length %> done)</h2>
  <table>
    <% tasks.forEach(t => { %>
      <tr><th><%= t.title %></th><td><span class="pill"><%= t.status.replace('_',' ') %></span>
        <% if (t.description) { %> — <%= t.description %><% } %></td></tr>
    <% }) %>
  </table>
  <% } %>

  <% if (typeof mapSvg !== 'undefined' && mapSvg) { %>
  <h2>Job location</h2>
  <div class="map-snapshot"><%- mapSvg %></div>
  <p class="meta">Captured from the gardener's GPS on this visit.<% if (mapLink) { %>
    <a href="<%= mapLink %>" target="_blank" rel="noopener">Open in map ↗</a><% } %></p>
  <% } %>

  <% if (comments.length) { %>
  <h2>Comments</h2>
  <% comments.forEach(c => { %>
    <div class="comment"><strong><%= c.author_name %></strong>
      <span class="meta">(<%= c.author_role %>) · <%= fmtDateTime(c.created_at) %></span><br><%= c.body %></div>
  <% }) %>
  <% } %>

  <h2>Photos (<%= photos.length %>)</h2>
  <% if (!photos.length) { %><p class="meta">No photos were uploaded for this job.</p><% } %>
  <div class="photos">
    <% photos.forEach(ph => { %>
      <figure>
        <img src="<%= photoSrc(ph) %>" alt="<%= ph.caption || ph.filename %>">
        <figcaption><span class="stamp">📅 <%= fmtDateTime(ph.created_at) %></span>
          <% if (ph.caption) { %> · <%= ph.caption %><% } %> · by <%= ph.uploader_name %></figcaption>
      </figure>
    <% }) %>
  </div>

  <footer>Generated by GardeningMgt on <%= generatedAt %>.</footer>
  <p class="no-print"><button data-print>Print / save as PDF</button></p>
</div>
<script src="/js/report.js" defer></script>
</body>
</html>
