<%- include('../partials/header') %>
<div class="page-head">
  <h1>Notifications</h1>
  <% if (notifications.some(n => !n.read_at)) { %>
  <form method="post" action="/notifications/read-all"><button class="btn btn-sm">Mark all read</button></form>
  <% } %>
</div>
<div class="card">
  <% notifications.forEach(n => { %>
    <div class="notification <%= n.read_at ? '' : 'unread' %>">
      <span class="tag tag-<%= n.type === 'job_summary' ? 'supervisor' : 'gardener' %>"><%= n.type.replace('_',' ') %></span>
      <%= n.message %>
      <% if (n.visit_id) { %> · <a href="/notifications/<%= n.id %>/open">view job</a><% } %>
      <% if (!n.read_at) { %>
        · <form method="post" action="/notifications/<%= n.id %>/read" class="inline"><button class="link-btn">Mark read</button></form>
      <% } %>
      <br><span class="muted"><%= fmtDateTime(n.created_at) %></span>
    </div>
  <% }) %>
  <% if (!notifications.length) { %><p class="muted">No notifications.</p><% } %>
</div>
<%- include('../partials/footer') %>
