<%- include('../partials/header') %>
<h1>Route planner</h1>

<div class="card">
  <form method="get" class="filter-row">
    <label>Date <input type="date" name="date" value="<%= date %>"></label>
    <% if (staff) { %>
    <label>Gardener
      <select name="gardener_id">
        <option value="">— pick —</option>
        <% gardeners.forEach(g => { %>
          <option value="<%= g.id %>" <%= g.id === gardenerId ? 'selected' : '' %>><%= g.name %></option>
        <% }) %>
      </select>
    </label>
    <% } %>
    <button class="btn">Show route</button>
  </form>
</div>

<% if (locals.allCount != null) { %>
  <% if (locals.allCount > 0) { %>
    <p class="alert alert-ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg> Optimized <%= allCount %> gardener<%= allCount === 1 ? '' : 's' %>'
      route<%= allCount === 1 ? '' : 's' %> for <%= date %> (<%= allVisits %> visit<%= allVisits === 1 ? '' : 's' %> reordered).
      <% if (locals.optimized === 'straight') { %>Note: the road-distance service was unavailable for at least one
        gardener, so that route was ordered by straight-line distance instead.<% } %></p>
  <% } else { %>
    <p class="alert alert-error">No gardeners had visits scheduled on <%= date %> — nothing to optimize.</p>
  <% } %>
<% } %>
<% if (gardenerId) { %>
<% if (locals.optimized === 'road') { %>
  <p class="alert alert-ok"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg> Route optimized by driving distance (road network).</p>
<% } else if (locals.optimized === 'straight') { %>
  <p class="alert alert-error">Route optimized by straight-line distance — the road-distance service was unavailable, so this is an approximation.</p>
<% } %>
<div class="card">
  <div class="filter-row">
    <form method="post" action="/routes/optimize"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="date" value="<%= date %>">
      <input type="hidden" name="gardener_id" value="<%= gardenerId %>">
      <button class="btn btn-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg> Optimize this route</button>
    </form>
    <% if (staff) { %>
    <form method="post" action="/routes/optimize-all"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <input type="hidden" name="date" value="<%= date %>">
      <button class="btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg> Optimize all gardeners for <%= date %></button>
    </form>
    <% } %>
    <% if (totalKm > 0) { %><p>Current route length: <strong>~<%= totalKm.toFixed(1) %> km straight-line</strong>
      <span class="muted">(actual driving distance will be longer)</span></p><% } %>
  </div>

  <ol class="route-list">
    <% visits.forEach(v => { %>
    <li>
      <a href="/visits/<%= v.id %>"><strong><%= v.property_name %></strong></a>
      — <%= v.address %>
      <% if (v.time_window) { %><span class="muted">(<%= v.time_window %>)</span><% } %>
      <span class="status status-<%= v.status %>"><%= v.status.replace('_',' ') %></span>
      <% if (v.lat == null) { %><span class="muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg> no coordinates — left at end of route</span><% } %>
    </li>
    <% }) %>
  </ol>
  <% if (!visits.length) { %>
    <div class="empty">
      <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 4 3 6.5v13L9 17l6 2.5 6-2.5v-13L15 6.5 9 4Z"/><path d="M9 4v13"/><path d="M15 6.5v13"/></svg></span>
      <p>No visits for this gardener on <%= date %>.</p>
    </div>
  <% } %>
</div>
<% } else { %>
<div class="card"><p class="muted">Pick a gardener and date to view and optimize their route.</p></div>
<% } %>
<%- include('../partials/footer') %>
