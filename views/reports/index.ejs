<%- include('../partials/header') %>
<h1>Reports</h1>

<div class="card">
  <form method="get" class="filter-row">
    <label>From <input type="date" name="from" value="<%= from %>"></label>
    <label>To <input type="date" name="to" value="<%= to %>"></label>
    <button class="btn">Run report</button>
    <a class="btn" href="/reports/export.csv?from=<%= from %>&to=<%= to %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M4 19.5h16"/></svg> Visits CSV</a>
    <a class="btn" href="/reports/export-invoices.csv?from=<%= from %>&to=<%= to %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M4 19.5h16"/></svg> Invoices CSV</a>
    <a class="btn" href="/reports/export-issues.csv?from=<%= from %>&to=<%= to %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M4 19.5h16"/></svg> Issues CSV</a>
  </form>
</div>

<div class="grid">
  <section class="card">
    <h2>Jobs by status</h2>
    <table class="table">
      <% visitStats.forEach(s => { %>
        <% const drill = '/visits?status=' + s.status + '&from=' + from + '&to=' + to; %>
        <tr>
          <td><a href="<%= drill %>"><span class="status status-<%= s.status %>"><%= s.status.replace('_',' ') %></span></a></td>
          <td><a href="<%= drill %>"><%= s.count %> →</a></td>
        </tr>
      <% }) %>
    </table>
    <% if (!visitStats.length) { %>
      <div class="empty">
        <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="2.5"/><path d="M8.5 7V5.5A2.5 2.5 0 0 1 11 3h2a2.5 2.5 0 0 1 2.5 2.5V7"/><path d="M3 12.5h18"/></svg></span>
        <p>No visits in range.</p>
      </div>
    <% } %>
    <% if (visitStats.length) { %><p class="muted">Tap a status to see those jobs.</p><% } %>
  </section>

  <section class="card">
    <h2>Per gardener</h2>
    <table class="table table--stack">
      <tr class="thead-row"><th>Gardener</th><th>Visits</th><th>Completed</th><th>Hours</th></tr>
      <% perGardener.forEach(g => { %>
        <tr><td class="stack-main"><%= g.name %></td><td data-label="Visits"><%= g.visits %></td><td data-label="Completed"><%= g.completed %></td>
          <td data-label="Hours"><%= (g.minutes / 60).toFixed(1) %></td></tr>
      <% }) %>
    </table>
  </section>

  <section class="card">
    <h2>Issues by status</h2>
    <table class="table">
      <% issueStats.forEach(s => { %>
        <tr><td><span class="status status-<%= s.status %>"><%= s.status.replace('_',' ') %></span></td><td><%= s.count %></td></tr>
      <% }) %>
    </table>
    <% if (!issueStats.length) { %>
      <div class="empty">
        <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg></span>
        <p>No issues in range.</p>
      </div>
    <% } %>
  </section>

  <section class="card">
    <h2>Invoicing</h2>
    <table class="table table--stack">
      <tr class="thead-row"><th>Status</th><th>Count</th><th>Total</th></tr>
      <% invoiceStats.forEach(s => { %>
        <tr><td class="stack-main"><span class="status status-<%= s.status %>"><%= s.status %></span></td>
          <td data-label="Count"><%= s.count %></td><td data-label="Total">$<%= s.total.toFixed(2) %></td></tr>
      <% }) %>
    </table>
    <p class="muted">Photos uploaded in range: <%= photoCount %></p>
  </section>
</div>
<%- include('../partials/footer') %>
