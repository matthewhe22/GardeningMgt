<%- include('../partials/header') %>
<h1><%= invoice.number %> <span class="status status-<%= invoice.status %>"><%= invoice.status %></span></h1>
<p class="muted">
  <%= invoice.property_name %>, <%= invoice.address %> · Job on <%= invoice.scheduled_date %>
  (<a href="/visits/<%= invoice.visit_id %>">job #<%= invoice.visit_id %></a>)
  <% if (invoice.gardener_name) { %> · Gardener: <%= invoice.gardener_name %><% } %>
  <% if (invoice.issued_at) { %> · Issued <%= invoice.issued_at %><% } %>
  <% if (invoice.paid_at) { %> · Paid <%= invoice.paid_at %><% } %>
</p>

<div class="card">
  <table class="table">
    <tr><th>Description</th><th>Qty</th><th>Unit price</th><th>Amount</th><th></th></tr>
    <% invoice.items.forEach(it => { %>
    <tr>
      <td><%= it.description %></td>
      <td><%= it.quantity %></td>
      <td>$<%= it.unit_price.toFixed(2) %></td>
      <td>$<%= (it.quantity * it.unit_price).toFixed(2) %></td>
      <td>
        <% if (invoice.status === 'draft') { %>
        <form method="post" action="/invoices/<%= invoice.id %>/items/<%= it.id %>/delete" class="inline">
          <button class="link-btn">✕</button>
        </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
    <tr><td colspan="3"><strong>Total</strong></td><td><strong>$<%= invoice.total.toFixed(2) %></strong></td><td></td></tr>
  </table>

  <% if (invoice.status === 'draft') { %>
  <form method="post" action="/invoices/<%= invoice.id %>/items" class="filter-row">
    <input type="text" name="description" placeholder="Description" required>
    <input type="number" name="quantity" placeholder="Qty" step="0.01" value="1" required>
    <input type="number" name="unit_price" placeholder="Unit price" step="0.01" required>
    <button class="btn">Add line</button>
  </form>
  <% } %>

  <form method="post" action="/invoices/<%= invoice.id %>/status" class="filter-row">
    <label>Status
      <select name="status">
        <% ['draft','sent','paid','void'].forEach(s => { %>
          <option value="<%= s %>" <%= invoice.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn btn-primary">Update status</button>
  </form>
</div>
<%- include('../partials/footer') %>
