<%- include('../partials/header') %>
<h1>Invoices</h1>
<p class="muted">Create invoices from a job page — the labour line is pre-filled from the job timer.</p>
<% if (locals.error === 'notcompleted') { %>
  <p class="alert alert-error">Can't create an invoice for a job that hasn't been completed yet.</p>
<% } %>
<% if (locals.deleted) { %><p class="alert alert-ok">Draft invoice deleted.</p><% } %>
<div class="card">
  <form method="get" class="filter-row">
    <label>Search <input type="text" name="search" value="<%= search %>" placeholder="Number or site"></label>
    <button class="btn">Search</button>
  </form>
</div>
<div class="card">
  <table class="table table--stack">
    <tr class="thead-row"><th>Number</th><th>Property</th><th>Job date</th><th>Total</th><th>Status</th><th>Created</th></tr>
    <% invoices.forEach(inv => { %>
    <tr>
      <td class="stack-main"><a href="/invoices/<%= inv.id %>"><strong><%= inv.number %></strong></a></td>
      <td data-label="Property"><%= inv.property_name %></td>
      <td class="muted" data-label="Job date"><%= inv.scheduled_date %></td>
      <td data-label="Total">$<%= inv.total.toFixed(2) %></td>
      <td data-label="Status"><span class="status status-<%= inv.status %>"><%= inv.status %></span></td>
      <td class="muted" data-label="Created"><%= fmtDateTime(inv.created_at) %></td>
    </tr>
    <% }) %>
  </table>
  <% if (!invoices.length) { %>
    <div class="empty">
      <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h9l4 4v14H6V3Z"/><path d="M14.5 3.5V8H19"/><path d="M9.5 13H15"/><path d="M9.5 16.5H15"/></svg></span>
      <p>No invoices yet.</p>
    </div>
  <% } %>
</div>
<%- include('../partials/pagination') %>
<%- include('../partials/footer') %>
