<%- include('../partials/header') %>
<h1>Sites</h1>

<% if (locals.imported !== undefined && imported !== null) { %>
  <p class="alert alert-ok">Imported <%= imported %> site(s).</p>
<% } %>
<% if (locals.importErrors) { %>
  <p class="alert alert-error">Some rows were skipped: <%= importErrors %></p>
<% } %>
<% if (locals.geocoded !== undefined && geocoded !== null) { %>
  <p class="alert alert-ok">Found coordinates for <%= geocoded %> site(s)<% if (Number(geoFailed) > 0) { %> · <%= geoFailed %> address(es) couldn't be matched<% } %><% if (Number(remaining) > 0) { %> · <strong><%= remaining %> still missing</strong> — click “Find missing coordinates” again to continue<% } else { %> · all sites now have coordinates 🎉<% } %>.</p>
<% } %>

<details class="card">
  <summary><strong>📥 Import sites from Excel / CSV</strong></summary>
  <form method="post" action="/admin/properties/import" enctype="multipart/form-data" class="filter-row"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="file" name="file" accept=".xlsx,.csv" required>
    <button class="btn btn-primary">Upload &amp; import</button>
  </form>
  <p class="muted">First row must be headers. Recognized columns:
    <code>Site Name</code> (required), <code>Address</code> (required),
    <code># of Lots</code>, <code>Lat</code>, <code>Lng</code>,
    <code>Contact</code>, <code>Phone</code>, <code>Notes</code>.
    Column order doesn't matter; extra columns are ignored.</p>
</details>

<details class="card">
  <summary><strong>＋ Add a single site</strong></summary>
  <form method="post" action="/admin/properties" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Site name <input type="text" name="name" required></label>
    <label>Address <input type="text" name="address" required></label>
    <label>Contact name <input type="text" name="contact_name"></label>
    <label>Contact phone <input type="text" name="contact_phone"></label>
    <label>Contact email <input type="email" name="contact_email"></label>
    <label># of lots <input type="number" name="lots" min="0"></label>
    <label>Latitude <span class="muted">(optional)</span> <input type="number" name="lat" step="any" placeholder="auto from address"></label>
    <label>Longitude <span class="muted">(optional)</span> <input type="number" name="lng" step="any" placeholder="auto from address"></label>
    <label class="span2">Notes <input type="text" name="notes"></label>
    <button class="btn btn-primary">Add site</button>
  </form>
  <p class="muted">Coordinates enable route optimization. Leave latitude/longitude
    blank and they'll be looked up from the address automatically on save.</p>
</details>

<div class="card">
  <div class="card-head">
    <h2>Coordinates</h2>
    <% if (missingCoords > 0) { %>
    <form method="post" action="/admin/properties/geocode" class="inline"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <button class="btn btn-primary">📍 Find missing coordinates</button>
    </form>
    <% } %>
  </div>
  <% if (missingCoords > 0) { %>
    <p class="muted"><strong><%= missingCoords %></strong> site(s) have no coordinates and would be
      dropped to the end of any optimized route. Click the button to look them up from their
      addresses (processed in small batches — click again if any remain).</p>
  <% } else { %>
    <p class="muted">✓ Every site has coordinates — route optimization can use them all.</p>
  <% } %>
</div>

<h2><%= properties.length %> site<%= properties.length === 1 ? '' : 's' %></h2>
<% if (!properties.length) { %>
  <div class="card"><p class="muted">No sites yet — import a spreadsheet or add one above.</p></div>
<% } %>
<% properties.forEach(p => { %>
<details class="card">
  <summary>
    <strong><%= p.name %></strong>
    <span class="muted">· <%= p.address %></span>
    <% if (p.contact_email) { %>
      <span class="muted">· <a href="mailto:<%= p.contact_email %>"><%= p.contact_email %></a></span>
    <% } %>
    <% if (p.lat != null && p.lng != null) { %>
      <span class="status status-completed"><%= p.lat.toFixed(4) %>, <%= p.lng.toFixed(4) %></span>
    <% } else { %>
      <span class="status status-open">⚠ no coordinates</span>
    <% } %>
  </summary>
  <form method="post" action="/admin/properties/<%= p.id %>/update" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Site name <input type="text" name="name" value="<%= p.name %>" required></label>
    <label>Address <input type="text" name="address" value="<%= p.address %>" required></label>
    <label>Contact name <input type="text" name="contact_name" value="<%= p.contact_name || '' %>"></label>
    <label>Contact phone <input type="text" name="contact_phone" value="<%= p.contact_phone || '' %>"></label>
    <label>Contact email <input type="email" name="contact_email" value="<%= p.contact_email || '' %>"></label>
    <label># of lots <input type="number" name="lots" min="0" value="<%= p.lots != null ? p.lots : '' %>"></label>
    <label class="span2">&nbsp;</label>
    <label>Latitude <input type="number" name="lat" step="any" value="<%= p.lat != null ? p.lat : '' %>"></label>
    <label>Longitude <input type="number" name="lng" step="any" value="<%= p.lng != null ? p.lng : '' %>"></label>
    <label class="span2 confirm-line"><input type="checkbox" name="regeocode">
      ↻ Re-detect coordinates from the address (overrides the lat/lng above)</label>
    <label class="span2">Notes <input type="text" name="notes" value="<%= p.notes || '' %>"></label>
    <button class="btn btn-primary">Save changes</button>
  </form>
  <p class="muted">Changed the address? Tick “Re-detect” (or clear lat/lng) and save to look up new coordinates.</p>
</details>
<% }) %>
<%- include('../partials/footer') %>
