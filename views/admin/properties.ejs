<%- include('../partials/header') %>
<h1>Sites</h1>

<% if (locals.imported !== undefined && imported !== null) { %>
  <p class="alert alert-ok">Imported <%= imported %> site(s).</p>
<% } %>
<% if (locals.importErrors) { %>
  <p class="alert alert-error">Some rows were skipped: <%= importErrors %></p>
<% } %>
<% if (locals.geocoded !== undefined && geocoded !== null) { %>
  <p class="alert alert-ok">Found coordinates for <%= geocoded %> site(s)<% if (Number(geoFailed) > 0) { %> · <%= geoFailed %> address(es) couldn't be matched<% } %><% if (Number(remaining) > 0) { %> · <strong><%= remaining %> still missing</strong> — click “Find missing coordinates” again to continue<% } else { %> · all sites now have coordinates 🎉<% } %>.</p>
<% } %>

<details class="card">
  <summary><strong>📥 Import sites from Excel / CSV</strong></summary>
  <form method="post" action="/admin/properties/import" enctype="multipart/form-data" class="filter-row">
    <input type="file" name="file" accept=".xlsx,.csv" required>
    <button class="btn btn-primary">Upload &amp; import</button>
  </form>
  <p class="muted">First row must be headers. Recognized columns:
    <code>Site Name</code> (required), <code>Address</code> (required),
    <code># of Lots</code>, <code>Lat</code>, <code>Lng</code>,
    <code>Contact</code>, <code>Phone</code>, <code>Notes</code>.
    Column order doesn't matter; extra columns are ignored.</p>
</details>

<details class="card">
  <summary><strong>＋ Add a single site</strong></summary>
  <form method="post" action="/admin/properties" class="form-grid">
    <label>Site name <input type="text" name="name" required></label>
    <label>Address <input type="text" name="address" required></label>
    <label>Contact name <input type="text" name="contact_name"></label>
    <label>Contact phone <input type="text" name="contact_phone"></label>
    <label># of lots <input type="number" name="lots" min="0"></label>
    <label>Latitude <span class="muted">(optional)</span> <input type="number" name="lat" step="any" placeholder="auto from address"></label>
    <label>Longitude <span class="muted">(optional)</span> <input type="number" name="lng" step="any" placeholder="auto from address"></label>
    <label class="span2">Notes <input type="text" name="notes"></label>
    <button class="btn btn-primary">Add site</button>
  </form>
  <p class="muted">Coordinates enable route optimization. Leave latitude/longitude
    blank and they'll be looked up from the address automatically on save.</p>
</details>

<div class="card">
  <div class="card-head">
    <h2>Coordinates</h2>
    <% if (missingCoords > 0) { %>
    <form method="post" action="/admin/properties/geocode" class="inline">
      <button class="btn btn-primary">📍 Find missing coordinates</button>
    </form>
    <% } %>
  </div>
  <% if (missingCoords > 0) { %>
    <p class="muted"><strong><%= missingCoords %></strong> site(s) have no coordinates and would be
      dropped to the end of any optimized route. Click the button to look them up from their
      addresses (processed in small batches — click again if any remain).</p>
  <% } else { %>
    <p class="muted">✓ Every site has coordinates — route optimization can use them all.</p>
  <% } %>
</div>

<div class="card">
  <table class="table">
    <tr><th>Site</th><th>Address</th><th>Lots</th><th>Contact</th><th>Coordinates</th></tr>
    <% properties.forEach(p => { %>
    <tr>
      <td><strong><%= p.name %></strong></td>
      <td><%= p.address %></td>
      <td><%= p.lots != null ? p.lots : '—' %></td>
      <td class="muted"><%= p.contact_name || '' %> <%= p.contact_phone || '' %></td>
      <td class="muted"><%= p.lat != null ? p.lat.toFixed(4) + ', ' + p.lng.toFixed(4) : '⚠ none' %></td>
    </tr>
    <% }) %>
  </table>
  <% if (!properties.length) { %><p class="muted">No sites yet — import a spreadsheet or add one above.</p><% } %>
</div>
<%- include('../partials/footer') %>
