<%- include('../partials/header') %>
<div class="page-head">
  <h1>Settings</h1>
  <p class="page-sub">OneDrive archiving: when a job is completed, its report and photos are
    uploaded to the OneDrive below. Jobs complete normally even if OneDrive is not configured
    or unavailable — failures are recorded in the activity log.</p>
</div>

<% if (locals.dbPoolerRisk) { %>
  <p class="alert alert-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg>
    Running on Vercel with a direct (non-pooler) database connection. Under real traffic this can
    exhaust Postgres' connection slots and take the whole app down at once. Point
    <code>DATABASE_URL</code> at your provider's connection pooler (e.g. Supabase's port 6543, or
    Neon's "-pooler" host) — once switched, set <code>REQUIRE_DB_POOLER=1</code> to make this a
    hard boot-time failure instead of a warning.</p>
<% } %>
<% if (locals.saved) { %><p class="alert alert-ok">Settings saved.</p><% } %>
<% if (locals.test) { %>
  <p class="alert <%= test.ok ? 'alert-ok' : 'alert-error' %>">
    <% if (test.ok) { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg>
    <% } else { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
    <% } %> <%= test.message %></p>
<% } %>
<% if (locals.emailTest) { %>
  <p class="alert <%= emailTest.ok ? 'alert-ok' : 'alert-error' %>">
    <% if (emailTest.ok) { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg>
    <% } else { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
    <% } %> <%= emailTest.message %></p>
<% } %>
<% if (locals.piqTest) { %>
  <p class="alert <%= piqTest.ok ? 'alert-ok' : 'alert-error' %>">
    <% if (piqTest.ok) { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 5 5L19 7"/></svg>
    <% } else { %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
    <% } %> <%= piqTest.message %></p>
<% } %>
<% if (locals.brandingError) { %><p class="alert alert-error"><%= brandingError %></p><% } %>

<div class="card">
  <h2>Branding</h2>
  <p class="muted">Replace the leaf icon in the sidebar/top bar and the browser tab icon with your
    own. Leave either field blank to keep what's already set, or tick "Remove" to go back to the
    default leaf.</p>
  <form method="post" action="/admin/settings/branding" enctype="multipart/form-data" class="form-grid">
    <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Logo
      <input type="file" name="logo" accept="image/png,image/jpeg,image/gif,image/webp"></label>
    <% if (branding.logo) { %>
      <div class="brand-preview">
        <img src="<%= branding.logo %>" alt="Current logo" class="brand-preview-img">
        <label><input type="checkbox" name="remove_logo"> Remove logo</label>
      </div>
    <% } %>
    <label>Favicon
      <input type="file" name="favicon" accept="image/png,image/jpeg,image/gif,image/webp"></label>
    <% if (branding.favicon) { %>
      <div class="brand-preview">
        <img src="<%= branding.favicon %>" alt="Current favicon" class="brand-preview-img brand-preview-favicon">
        <label><input type="checkbox" name="remove_favicon"> Remove favicon</label>
      </div>
    <% } %>
    <button class="btn btn-primary">Save branding</button>
  </form>
</div>

<div class="card">
  <h2>OneDrive (Microsoft Graph)</h2>
  <form method="post" action="/admin/settings" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Tenant (Directory) ID
      <input type="text" name="onedrive_tenant_id" value="<%= settings.onedrive_tenant_id || '' %>" placeholder="00000000-0000-0000-0000-000000000000"></label>
    <label>Client (Application) ID
      <input type="text" name="onedrive_client_id" value="<%= settings.onedrive_client_id || '' %>"></label>
    <label>Client secret
      <input type="password" name="onedrive_client_secret"
        value="<%= settings.onedrive_client_secret ? '********' : '' %>"
        placeholder="<%= settings.onedrive_client_secret ? 'saved — leave as is to keep' : 'paste secret value' %>"></label>
    <label>Drive user (UPN)
      <input type="email" name="onedrive_drive_user" value="<%= settings.onedrive_drive_user || '' %>" placeholder="ops@yourcompany.com"></label>
    <label>Folder
      <input type="text" name="onedrive_folder" value="<%= settings.onedrive_folder || '' %>" placeholder="GardeningMgt"></label>
    <button class="btn btn-primary">Save settings</button>
  </form>
  <form method="post" action="/admin/settings/test" style="margin-top:8px"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <button class="btn">Test connection</button>
  </form>
</div>

<div class="card">
  <h2>Invoice details</h2>
  <p class="muted">Shown on every invoice PDF: business letterhead, GST/ABN, and the default
    payment terms used to set each new invoice's due date.</p>
  <form method="post" action="/admin/settings" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Business name
      <input type="text" name="invoice_business_name" value="<%= settings.invoice_business_name || '' %>" placeholder="e.g. Green Thumb Gardening Pty Ltd"></label>
    <label class="span2">Business address
      <input type="text" name="invoice_business_address" value="<%= settings.invoice_business_address || '' %>" placeholder="123 Example St, Melbourne VIC 3000"></label>
    <label>ABN / GST number
      <input type="text" name="invoice_business_abn" value="<%= settings.invoice_business_abn || '' %>" placeholder="e.g. 12 345 678 901"></label>
    <label>Default payment terms (days)
      <input type="number" name="invoice_payment_terms_days" min="0" step="1"
        value="<%= settings.invoice_payment_terms_days || 14 %>"></label>
    <label class="span2">Payment details (bank/BPAY etc. — shown on invoices)
      <input type="text" name="invoice_payment_details"
        value="<%= settings.invoice_payment_details ? '********' : '' %>"
        placeholder="<%= settings.invoice_payment_details ? 'saved — leave as is to keep' : 'e.g. BSB 000-000, Acc 000000000' %>"></label>
    <button class="btn btn-primary">Save settings</button>
  </form>
</div>

<div class="card">
  <h2>Email (invoice sending)</h2>
  <p class="muted">When a job completes, its invoice is emailed automatically to the site's
    billing email (set per-site on the Properties page). Configure any SMTP account below —
    a normal mailbox (Gmail, Office 365, etc. — usually needs an "app password") or an SMTP
    relay from your host/provider both work.</p>
  <form method="post" action="/admin/settings" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>SMTP host
      <input type="text" name="smtp_host" value="<%= settings.smtp_host || '' %>" placeholder="smtp.gmail.com"></label>
    <label>Port
      <input type="number" name="smtp_port" min="1" step="1" value="<%= settings.smtp_port || 587 %>"></label>
    <label>Username
      <input type="text" name="smtp_user" value="<%= settings.smtp_user || '' %>" placeholder="ops@yourcompany.com"></label>
    <label>Password
      <input type="password" name="smtp_password"
        value="<%= settings.smtp_password ? '********' : '' %>"
        placeholder="<%= settings.smtp_password ? 'saved — leave as is to keep' : 'app password or SMTP password' %>"></label>
    <label>From email
      <input type="email" name="smtp_from_email" value="<%= settings.smtp_from_email || '' %>" placeholder="invoices@yourcompany.com"></label>
    <label>From name <span class="muted">(optional)</span>
      <input type="text" name="smtp_from_name" value="<%= settings.smtp_from_name || '' %>" placeholder="e.g. Green Thumb Gardening"></label>
    <button class="btn btn-primary">Save settings</button>
  </form>
  <form method="post" action="/admin/settings/test-email" style="margin-top:8px"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <button class="btn">Test connection</button>
  </form>
</div>

<div class="card">
  <h2>PropertyIQ (owner report sending)</h2>
  <p class="muted">Lets a supervisor send a completed job report straight to a building's owners.
    The site is matched to a PropertyIQ building by address, and owner emails are pulled from
    that building's lots — see the "Send report to owners" button on a completed job.</p>
  <form method="post" action="/admin/settings" class="form-grid"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Base URL
      <input type="text" name="piq_base_url" value="<%= settings.piq_base_url || '' %>" placeholder="https://tocs.propertyiq.com.au"></label>
    <label>Client ID
      <input type="text" name="piq_client_id" value="<%= settings.piq_client_id || '' %>"></label>
    <label>Client secret
      <input type="password" name="piq_client_secret"
        value="<%= settings.piq_client_secret ? '********' : '' %>"
        placeholder="<%= settings.piq_client_secret ? 'saved — leave as is to keep' : 'paste secret value' %>"></label>
    <label>Scopes <span class="muted">(optional)</span>
      <input type="text" name="piq_scope" value="<%= settings.piq_scope || '' %>" placeholder="buildings lots"></label>
    <button class="btn btn-primary">Save settings</button>
  </form>
  <form method="post" action="/admin/settings/test-piq" style="margin-top:8px"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <button class="btn">Test connection</button>
  </form>
</div>

<div class="card">
  <h2>How to set this up in Azure</h2>
  <ol class="muted" style="line-height:1.9">
    <li>Go to <strong>portal.azure.com → Microsoft Entra ID → App registrations → New registration</strong>.</li>
    <li>Copy the <strong>Application (client) ID</strong> and <strong>Directory (tenant) ID</strong> into the form above.</li>
    <li>Under <strong>Certificates &amp; secrets</strong>, create a client secret and paste its <em>value</em> above.</li>
    <li>Under <strong>API permissions</strong>, add Microsoft Graph → <strong>Application permissions</strong> →
      <code>Files.ReadWrite.All</code>, then click <strong>Grant admin consent</strong>.</li>
    <li>Set <strong>Drive user</strong> to the account whose OneDrive should receive the files.</li>
    <li>Click <strong>Test connection</strong> to verify.</li>
  </ol>
</div>
<%- include('../partials/footer') %>
