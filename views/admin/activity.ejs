<%- include('../partials/header') %>
<h1>Activity log</h1>
<p class="muted">Every change in the system is recorded here: who did what, and when.</p>
<div class="card">
  <table class="table table--stack">
    <tr class="thead-row"><th>When</th><th>Who</th><th>Action</th><th>Details</th></tr>
    <% entries.forEach(e => { %>
    <tr>
      <td class="muted stack-main" data-label="When"><%= fmtDateTime(e.created_at) %></td>
      <td data-label="Who"><%= e.user_name || 'System' %></td>
      <td data-label="Action"><code><%= e.action %></code></td>
      <td data-label="Details"><%= e.details || '' %></td>
    </tr>
    <% }) %>
  </table>
  <% if (!entries.length) { %><p class="muted">No activity yet.</p><% } %>
</div>
<%- include('../partials/pagination') %>
<%- include('../partials/footer') %>
