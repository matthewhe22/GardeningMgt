<%- include('../partials/header') %>
<h1>Visit reminders</h1>
<p class="muted">Automatic reminders go out every morning at 06:00 for the day's visits.
  Use bulk send to remind everyone now (e.g. for tomorrow's schedule).</p>

<% if (sent !== undefined && sent !== null) { %>
  <p class="alert alert-ok">Sent <%= sent %> reminder(s).</p>
<% } %>

<div class="card">
  <form method="post" action="/admin/reminders/bulk" class="filter-row"><% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <label>Date <input type="date" name="date" value="<%= date %>"></label>
    <label><input type="checkbox" name="force"> Re-send even if already reminded</label>
    <button class="btn btn-primary">📣 Send bulk reminders</button>
  </form>
</div>

<div class="card">
  <h2>Scheduled visits on <%= date %></h2>
  <table class="table">
    <tr><th>Gardener</th><th>Property</th><th>Window</th><th>Reminder</th></tr>
    <% pending.forEach(v => { %>
    <tr>
      <td><%= v.gardener_name || '⚠ Unassigned' %></td>
      <td><a href="/visits/<%= v.id %>"><%= v.property_name %></a></td>
      <td class="muted"><%= v.time_window || '—' %></td>
      <td><%= v.reminder_sent_at ? '✅ ' + fmtDateTime(v.reminder_sent_at) : 'not sent' %></td>
    </tr>
    <% }) %>
  </table>
  <% if (!pending.length) { %>
    <div class="empty">
      <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="7.5"/><path d="M12 9.5V13l2.5 2"/><path d="m4.5 4-2 2"/><path d="m19.5 4 2 2"/></svg></span>
      <p>No scheduled visits on this date.</p>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
