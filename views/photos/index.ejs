<%- include('../partials/header') %>
<h1>Photo gallery</h1>
<p class="muted">Photos shared by the team. Every photo carries its upload timestamp. Upload photos from a job or issue page.</p>

<% if (staff) { %>
<div class="card">
  <form method="get" class="filter-row">
    <label>From <input type="date" name="from" value="<%= from %>"></label>
    <label>To <input type="date" name="to" value="<%= to %>"></label>
    <label>Site
      <select name="property_id">
        <option value="">All sites</option>
        <% properties.forEach(p => { %>
          <option value="<%= p.id %>" <%= String(p.id) === String(propertyId) ? 'selected' : '' %>><%= p.name %></option>
        <% }) %>
      </select>
    </label>
    <label>Gardener
      <select name="gardener_id">
        <option value="">All gardeners</option>
        <% gardeners.forEach(g => { %>
          <option value="<%= g.id %>" <%= String(g.id) === String(gardenerId) ? 'selected' : '' %>><%= g.name %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn">Filter</button>
    <% if (from || to || propertyId || gardenerId) { %><a class="btn btn-sm" href="/photos">Clear</a><% } %>
  </form>
</div>
<% } %>

<div class="photo-grid large">
  <% photos.forEach(ph => { %>
    <figure class="photo">
      <a href="/uploads/<%= ph.filename %>" target="_blank"><img src="/uploads/<%= ph.filename %>/thumb" alt="<%= ph.caption || ph.original_name %>" loading="lazy"></a>
      <figcaption>
        <span class="photo-stamp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M8 3v4M16 3v4M3.5 10h17"/></svg> <%= fmtDateTime(ph.created_at) %></span><br>
        <% if (ph.caption) { %><%= ph.caption %><br><% } %>
        <span class="muted">by <%= ph.uploader_name %>
          <% if (ph.visit_ref) { %> · <a href="/visits/<%= ph.visit_ref %>">visit #<%= ph.visit_ref %><% if (ph.property_name) { %> (<%= ph.property_name %>)<% } %></a><% } %>
          <% if (ph.issue_id) { %> · <a href="/issues/<%= ph.issue_id %>">issue: <%= ph.issue_title %></a><% } %>
        </span>
      </figcaption>
    </figure>
  <% }) %>
</div>
<% if (!photos.length) { %>
<div class="card">
  <div class="empty">
    <span class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h3l2-2.5h6L17 7h3a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.5"/></svg></span>
    <% if (staff && (from || to || propertyId || gardenerId)) { %>
      <p>No photos match these filters. <a href="/photos">Clear filters</a></p>
    <% } else { %>
      <p>No photos yet.</p>
    <% } %>
  </div>
</div>
<% } %>
<%- include('../partials/pagination') %>
<%- include('../partials/footer') %>
