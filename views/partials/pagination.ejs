<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<nav class="pagination" aria-label="Pagination">
  <% if (page > 1) { %><a class="btn btn-sm" href="<%= pageUrl(page - 1) %>">← Prev</a>
  <% } else { %><span class="btn btn-sm" aria-disabled="true">← Prev</span><% } %>
  <span class="muted pagination-info">Page <%= page %> of <%= totalPages %> · <%= total %> total</span>
  <% if (page < totalPages) { %><a class="btn btn-sm" href="<%= pageUrl(page + 1) %>">Next →</a>
  <% } else { %><span class="btn btn-sm" aria-disabled="true">Next →</span><% } %>
</nav>
<% } %>
