<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title><%= title %> · GardeningMgt</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f3424">
</head>
<body class="<%= locals.user ? 'authed' : 'anon' %>">
<% if (locals.user) { %>
<%
  const staffNav = user.role === 'admin' || user.role === 'supervisor';
  const active = (p) => ((p === '/' ? currentPath === '/' : currentPath.startsWith(p)) ? ' active' : '');
  const icons = {
    home: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5 12 3.5l9 7"/><path d="M5.5 9.5V20a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1V9.5"/><path d="M9.5 21v-6h5v6"/></svg>',
    jobs: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="2.5"/><path d="M8.5 7V5.5A2.5 2.5 0 0 1 11 3h2a2.5 2.5 0 0 1 2.5 2.5V7"/><path d="M3 12.5h18"/></svg>',
    tasks: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>',
    issues: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.3 4.1 2.9 17a2 2 0 0 0 1.7 3h14.8a2 2 0 0 0 1.7-3L13.7 4.1a2 2 0 0 0-3.4 0Z"/><path d="M12 9v4.5"/><path d="M12 16.8h.01"/></svg>',
    photos: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h3l2-2.5h6L17 7h3a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.5"/></svg>',
    routes: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 4 3 6.5v13L9 17l6 2.5 6-2.5v-13L15 6.5 9 4Z"/><path d="M9 4v13"/><path d="M15 6.5v13"/></svg>',
    bell: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 9a6 6 0 1 0-12 0c0 5-2 6.5-2 6.5h16S18 14 18 9Z"/><path d="M10 19a2.2 2.2 0 0 0 4 0"/></svg>',
    invoices: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h9l4 4v14H6V3Z"/><path d="M14.5 3.5V8H19"/><path d="M9.5 13H15"/><path d="M9.5 16.5H15"/></svg>',
    reports: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20h16"/><path d="M6.5 16v-5"/><path d="M11 16V6"/><path d="M15.5 16v-8"/><path d="M20 16v-4"/></svg>',
    reminders: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="7.5"/><path d="M12 9.5V13l2.5 2"/><path d="m4.5 4-2 2"/><path d="m19.5 4 2 2"/></svg>',
    properties: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10.5c0 5.5-8 11-8 11s-8-5.5-8-11a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10.5" r="3"/></svg>',
    activity: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12h4l3-7 4 14 3-7h4"/></svg>',
    users: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20a6.5 6.5 0 0 1 13 0"/><path d="M16 5a3.5 3.5 0 0 1 0 7"/><path d="M17.5 14.5a6.5 6.5 0 0 1 4 5.5"/></svg>',
    logout: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 4H6a1.5 1.5 0 0 0-1.5 1.5v13A1.5 1.5 0 0 0 6 20h8"/><path d="m16.5 8 4 4-4 4"/><path d="M20 12H9.5"/></svg>',
    more: '<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>',
    repeat: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>',
    gear: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3.2"/><path d="M19.4 13.5a1.6 1.6 0 0 0 .32 1.76l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.6 1.6 0 0 0-1.76-.32 1.6 1.6 0 0 0-.97 1.46V19.5a2 2 0 1 1-4 0v-.09a1.6 1.6 0 0 0-1.05-1.46 1.6 1.6 0 0 0-1.76.32l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.6 1.6 0 0 0 .32-1.76 1.6 1.6 0 0 0-1.46-.97H4.5a2 2 0 1 1 0-4h.09a1.6 1.6 0 0 0 1.46-1.05 1.6 1.6 0 0 0-.32-1.76l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.6 1.6 0 0 0 1.76.32h.09a1.6 1.6 0 0 0 .97-1.46V4.5a2 2 0 1 1 4 0v.09a1.6 1.6 0 0 0 .97 1.46 1.6 1.6 0 0 0 1.76-.32l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.6 1.6 0 0 0-.32 1.76v.09a1.6 1.6 0 0 0 1.46.97h.09a2 2 0 1 1 0 4h-.09a1.6 1.6 0 0 0-1.46.97Z"/></svg>'
  };
%>
<aside class="sidebar">
  <a class="sidebar-brand" href="/"><span class="brand-mark">🌱</span> GardeningMgt</a>
  <nav class="sidebar-nav" aria-label="Main navigation">
    <div class="nav-label">Workspace</div>
    <a href="/" class="nav-item<%= active('/') %>"><%- icons.home %> Dashboard</a>
    <a href="/visits" class="nav-item<%= active('/visits') %>"><%- icons.jobs %> Jobs</a>
    <a href="/jobs" class="nav-item<%= active('/jobs') %>"><%- icons.repeat %> Site jobs</a>
    <a href="/tasks" class="nav-item<%= active('/tasks') %>"><%- icons.tasks %> Tasks</a>
    <a href="/issues" class="nav-item<%= active('/issues') %>"><%- icons.issues %> Issues</a>
    <a href="/photos" class="nav-item<%= active('/photos') %>"><%- icons.photos %> Photos</a>
    <a href="/routes" class="nav-item<%= active('/routes') %>"><%- icons.routes %> Routes</a>
    <a href="/notifications" class="nav-item<%= active('/notifications') %>"><%- icons.bell %> Notifications<% if (unreadCount > 0) { %><span class="badge"><%= unreadCount %></span><% } %></a>
    <% if (staffNav) { %>
      <div class="nav-label">Management</div>
      <a href="/invoices" class="nav-item<%= active('/invoices') %>"><%- icons.invoices %> Invoices</a>
      <a href="/reports" class="nav-item<%= active('/reports') %>"><%- icons.reports %> Reports</a>
      <a href="/admin/reminders" class="nav-item<%= active('/admin/reminders') %>"><%- icons.reminders %> Reminders</a>
      <a href="/admin/properties" class="nav-item<%= active('/admin/properties') %>"><%- icons.properties %> Properties</a>
      <a href="/admin/activity" class="nav-item<%= active('/admin/activity') %>"><%- icons.activity %> Activity</a>
    <% } %>
    <% if (user.role === 'admin') { %>
      <a href="/admin/users" class="nav-item<%= active('/admin/users') %>"><%- icons.users %> Users</a>
      <a href="/admin/settings" class="nav-item<%= active('/admin/settings') %>"><%- icons.gear %> Settings</a>
    <% } %>
  </nav>
  <div class="sidebar-foot">
    <span class="avatar" aria-hidden="true"><%= user.name.trim().charAt(0).toUpperCase() %></span>
    <div class="sidebar-user">
      <div class="name"><%= user.name %></div>
      <div class="role"><%= user.role %></div>
    </div>
    <form method="post" action="/logout" class="inline"><button class="signout-btn" title="Sign out · <%= user.name %>" aria-label="Sign out"><%- icons.logout %></button></form>
  </div>
</aside>

<header class="topbar">
  <a class="topbar-brand" href="/"><span class="brand-mark">🌱</span> GardeningMgt</a>
  <label for="nav-toggle" class="topbar-action" role="button" aria-label="More menu"><%- icons.more %></label>
</header>

<nav class="tabbar" aria-label="Quick navigation">
  <div class="tabbar-inner">
    <a href="/" class="tab<%= active('/') %>"><%- icons.home %><span>Home</span></a>
    <a href="/visits" class="tab<%= active('/visits') %>"><%- icons.jobs %><span>Jobs</span></a>
    <a href="/routes" class="tab<%= active('/routes') %>"><%- icons.routes %><span>Routes</span></a>
    <a href="/issues" class="tab<%= active('/issues') %>"><%- icons.issues %><span>Issues</span></a>
    <a href="/notifications" class="tab<%= active('/notifications') %>"><%- icons.bell %><span>Alerts</span><% if (unreadCount > 0) { %><span class="badge"><%= unreadCount %></span><% } %></a>
  </div>
</nav>

<input type="checkbox" id="nav-toggle" class="menu-toggle nav-toggle">
<label for="nav-toggle" class="sheet-backdrop" aria-hidden="true"></label>
<div class="sheet" aria-label="More options">
  <div class="sheet-handle"></div>
  <a href="/jobs" class="nav-item<%= active('/jobs') %>"><%- icons.repeat %> Site jobs</a>
  <a href="/tasks" class="nav-item<%= active('/tasks') %>"><%- icons.tasks %> Tasks</a>
  <a href="/photos" class="nav-item<%= active('/photos') %>"><%- icons.photos %> Photos</a>
  <a href="/notifications" class="nav-item<%= active('/notifications') %>"><%- icons.bell %> Notifications<% if (unreadCount > 0) { %><span class="badge"><%= unreadCount %></span><% } %></a>
  <% if (staffNav) { %>
    <div class="nav-label">Management</div>
    <a href="/invoices" class="nav-item<%= active('/invoices') %>"><%- icons.invoices %> Invoices</a>
    <a href="/reports" class="nav-item<%= active('/reports') %>"><%- icons.reports %> Reports</a>
    <a href="/admin/reminders" class="nav-item<%= active('/admin/reminders') %>"><%- icons.reminders %> Reminders</a>
    <a href="/admin/properties" class="nav-item<%= active('/admin/properties') %>"><%- icons.properties %> Properties</a>
    <a href="/admin/activity" class="nav-item<%= active('/admin/activity') %>"><%- icons.activity %> Activity</a>
  <% } %>
  <% if (user.role === 'admin') { %>
    <a href="/admin/users" class="nav-item<%= active('/admin/users') %>"><%- icons.users %> Users</a>
    <a href="/admin/settings" class="nav-item<%= active('/admin/settings') %>"><%- icons.gear %> Settings</a>
  <% } %>
  <div class="nav-label">Signed in as <%= user.name %></div>
  <form method="post" action="/logout" class="sheet-signout"><button class="nav-item"><%- icons.logout %> Sign out</button></form>
</div>
<% } %>
<main class="container">
